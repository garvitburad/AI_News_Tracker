# Google AI Studio Gemini API key for synthesis and LinkedIn generation
GEMINI_API_KEY=

# Backward compatibility (optional if GEMINI_API_KEY is set)
GOOGLE_GENAI_API_KEY=

# Optional: override default model
GENAI_MODEL=gemini-2.0-flash

# Gmail ingestion configuration
GMAIL_LABEL=AI-News
GOOGLE_OAUTH_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Optional social ingestion provider key (placeholder integration)
APIFY_API_KEY=

# RSS feeds as comma-separated URLs
RSS_FEEDS=https://feeds.feedburner.com/oreilly/radar/atom,https://www.marktechpost.com/feed,https://www.unite.ai/feed/
